{
  "name": "kompass-gateway",
  "version": "1.0.0",
  "type": "module",
  "description": "Classifier-routed free-model gateway for Claude Code — one Cloudflare Worker routes your coding sessions across free model providers by task complexity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinoth4v/kompass.git"
  },
  "homepage": "https://github.com/vinoth4v/kompass#readme",
  "keywords": [
    "claude-code",
    "llm-router",
    "cloudflare-workers",
    "free-models",
    "ai-gateway"
  ],
  "bin": {
    "kompass": "bin/kompass.mjs"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke.ts",
    "ui": "tsx src/ui/server.ts",
    "secrets:push": "wrangler secret bulk secrets/.secrets.json",
    "kompass": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@cloudflare/workers-types": "^4.20250701.0",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.16.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.0.0",
    "yaml": "^2.6.0"
  }
}
