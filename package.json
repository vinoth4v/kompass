{
  "name": "kompass",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Classifier-routed free-model gateway for Claude Code (Cloudflare Worker)",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
